# ---------------------------------------------------------------------------
# CrisisGrid Backend - Environment Variables
# Copy this file to ".env" and fill in real values. Never commit the real .env.
# ---------------------------------------------------------------------------

# Server
PORT=5000
NODE_ENV=development

# CORS - the URL your React frontend runs on
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string (free tier: https://www.mongodb.com/atlas)
# If left empty, the server automatically falls back to DEMO_MODE (see below).
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/crisisgrid

# JWT secrets - use long random strings in production
# (generate one quickly with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Google Gemini API key (free tier: https://aistudio.google.com/app/apikey)
# If left empty, the AI service automatically falls back to rule-based mock
# responses so the app remains fully demonstrable with zero external accounts.
GEMINI_API_KEY=

# Demo Mode - when true, the server seeds and serves the Mumbai Flood scenario
# and the AI service always uses the offline mock (never calls Gemini).
DEMO_MODE=true
